{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SopDocument",
  "description": "JSON Schema for SOP YAML source files (INTERFACES.md §1).",
  "type": "object",
  "required": ["sop_version", "name", "policy", "steps"],
  "additionalProperties": false,
  "properties": {
    "sop_version": {
      "type": "string",
      "description": "SOP schema version."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Stable SOP identifier."
    },
    "policy": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the policy file that sets the capability ceiling."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of steps in the SOP.",
      "items": {
        "type": "object",
        "required": ["id", "requires"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
            "description": "Stable step identifier."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable description of the step."
          },
          "requires": {
            "type": "object",
            "required": ["capabilities"],
            "additionalProperties": false,
            "properties": {
              "capabilities": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "description": "Capability strings required by this step."
              }
            }
          },
          "condition": {
            "type": "string",
            "minLength": 1,
            "description": "Natural language condition to evaluate. If present, the handler evaluates it and returns DONE (true) or FAILED (false)."
          },
          "on_success": {
            "type": "string",
            "minLength": 1,
            "description": "Target step id on success (or when condition is true)."
          },
          "on_failure": {
            "type": "string",
            "minLength": 1,
            "description": "Target step id on failure (or when condition is false)."
          },
          "terminal": {
            "type": "boolean",
            "default": false,
            "description": "Whether this is a terminal (end) step."
          },
          "loop": {
            "type": "object",
            "description": "Bounded loop configuration. Step repeats until condition is false or max_iterations is hit.",
            "additionalProperties": false,
            "properties": {
              "max_iterations": {
                "type": "integer",
                "minimum": 1,
                "description": "Maximum number of iterations before following on_limit edge."
              }
            }
          },
          "on_limit": {
            "type": "string",
            "minLength": 1,
            "description": "Target step id when loop max_iterations is exceeded."
          }
        }
      }
    }
  }
}
